<%- if controller_name != 'sessions' %>
  <p class="text-sm font-medium text-emerald-700">
    Sudah punya akun? <%= link_to "Masuk di sini", new_session_path(resource_name), class: "text-emerald-600 hover:text-emerald-800 font-bold underline decoration-emerald-200 underline-offset-4" %>
  </p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p class="text-sm font-medium text-emerald-700">
    Belum punya akun? <%= link_to "Daftar sekarang", new_registration_path(resource_name), class: "text-emerald-600 hover:text-emerald-800 font-bold underline decoration-emerald-200 underline-offset-4" %>
  </p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p class="text-sm">
    <%= link_to "Lupa kata sandi?", new_password_path(resource_name), class: "text-emerald-500 hover:text-emerald-700 font-semibold transition-colors" %>
  </p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p class="text-xs">
    <%= link_to "Tidak menerima instruksi konfirmasi?", new_confirmation_path(resource_name), class: "text-emerald-400 hover:text-emerald-600 transition-colors" %>
  </p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p class="text-xs">
    <%= link_to "Tidak menerima instruksi buka kunci?", new_unlock_path(resource_name), class: "text-emerald-400 hover:text-emerald-600 transition-colors" %>
  </p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p><%= button_to "Masuk dengan #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "w-full py-3 px-4 rounded-xl border-2 border-emerald-100 text-emerald-700 font-bold hover:bg-emerald-50 transition-all" %></p>
  <% end %>
<% end %>
