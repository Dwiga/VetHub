<div class="min-h-screen bg-emerald-50 flex flex-col items-center justify-center p-6 selection:bg-emerald-200 selection:text-emerald-900">
  <div class="w-full max-w-md bg-white/80 backdrop-blur-sm p-8 rounded-[2rem] border border-emerald-100 shadow-2xl shadow-emerald-100/50">
    
    <div class="flex flex-col items-center mb-8">
      <div class="bg-emerald-600 p-3 rounded-2xl shadow-lg shadow-emerald-200 mb-4 transform rotate-12">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </div>
      <h2 class="text-2xl font-black text-emerald-950 tracking-tight text-center leading-tight">Kirim Ulang Konfirmasi</h2>
      <p class="text-emerald-700/60 font-medium mt-1 text-center">Masukkan email Anda untuk menerima link konfirmasi</p>
    </div>

    <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-2">
        <%= f.label :email, "Alamat Email", class: "text-sm font-bold text-emerald-900 ml-1" %>
        <%= f.email_field :email, 
            autofocus: true, 
            autocomplete: "email", 
            value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
            placeholder: "email@contoh.com",
            class: "w-full px-5 py-4 rounded-2xl bg-emerald-50/50 border border-emerald-100 focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/10 transition-all outline-none text-emerald-950 placeholder:text-emerald-300" 
        %>
      </div>

      <div class="pt-2">
        <%= f.submit "Kirim Ulang Instruksi", 
            class: "w-full py-4 px-6 bg-emerald-600 hover:bg-emerald-700 text-white font-bold text-lg rounded-2xl shadow-xl shadow-emerald-200 transition-all hover:scale-[1.02] active:scale-[0.98] cursor-pointer" 
        %>
      </div>
    <% end %>

    <div class="mt-8 pt-6 border-t border-emerald-50 flex flex-col items-center space-y-4">
      <%= render "devise/shared/links" %>
    </div>
  </div>

  <div class="mt-8 flex items-center space-x-2 text-emerald-900/30 font-bold uppercase tracking-widest text-[10px]">
    <span>&copy; 2026 PawsVet</span>
    <span>•</span>
    <span>Caring for every paw</span>
  </div>
</div>
