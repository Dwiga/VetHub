# ─────────────────────────────────────────────────────────────────────────────
# VetCare Pro — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:  postgres://user:pass@localhost:5432/vetcare
# Docker:     set POSTGRES_PASSWORD below — DATABASE_URL is auto-constructed
# DATABASE_URL=postgres://vetcare:changeme@localhost:5432/vetcare
# DATABASE_URL=file:./prisma/dev.db
DATABASE_URL=postgresql://kZEiZlm:FSaOzK@aueskpewxpfo.db.dbaas.dev:31804/FSaOzK?sslmode=require

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get these from your Clerk dashboard → API Keys
# https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Also used by the Vite frontend build (baked into the JS bundle at build time)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# For production Clerk instances with a custom domain, set this to your
# Clerk Frontend API URL, e.g.: https://clerk.yourdomain.com
# Leave empty to use the default Clerk shared endpoint (fine for dev instances).
CLERK_FRONTEND_API_URL=

# Optional: route Clerk auth traffic through your own domain.
# Set to the full URL of the Clerk proxy endpoint on your domain, e.g.:
#   http://localhost/api/__clerk       (Docker local)
#   https://yourdomain.com/api/__clerk (production)
# Leave empty to connect directly to Clerk (fine for local dev).
VITE_CLERK_PROXY_URL=

# ── Session ────────────────────────────────────────────────────────────────────
# Use a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ── Docker Compose only ────────────────────────────────────────────────────────
# Password for the postgres container. DATABASE_URL is auto-built from this.
POSTGRES_PASSWORD=changeme
