# ─────────────────────────────────────────────────────────────────────────────
# VetCare Pro — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:  postgres://user:pass@localhost:5432/vetcare
# Docker:     set POSTGRES_PASSWORD below — DATABASE_URL is auto-constructed
DATABASE_URL=postgres://vetcare:changeme@localhost:5432/vetcare

# ── Stack Auth ────────────────────────────────────────────────────────────────
# Get these from your Stack Auth dashboard → https://app.stack-auth.com
STACK_PROJECT_ID=your-project-id
STACK_PUBLISHABLE_CLIENT_KEY=pck_...
STACK_SECRET_SERVER_KEY=ssk_...

# Also used by the Vite frontend build (baked into the JS bundle at build time)
VITE_STACK_PROJECT_ID=your-project-id
VITE_STACK_PUBLISHABLE_CLIENT_KEY=pck_...

# ── Session ────────────────────────────────────────────────────────────────────
# Use a long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# ── Docker Compose only ────────────────────────────────────────────────────────
# Password for the postgres container. DATABASE_URL is auto-built from this.
POSTGRES_PASSWORD=changeme
